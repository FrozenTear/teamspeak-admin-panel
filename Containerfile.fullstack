# TS6 Manager ‚Äî Dioxus fullstack server
# Multi-stage OCI Containerfile (Podman-native; works with any OCI runtime).
#
# Multi-arch: builds cleanly under `podman build --platform linux/amd64` and
# `--platform linux/arm64`; we publish a manifest list spanning both at release
# time. See docs/ops/images.md for the release procedure.

# -----------------------------------------------------------------------------
# Stage 1 ‚Äî build
# -----------------------------------------------------------------------------
FROM docker.io/rust:1.95-slim-bookworm AS builder

WORKDIR /build

# Build-time deps:
#   * `build-essential` ‚Äî gcc / libc6-dev for the dx bundle link step.
#   * `pkg-config` / `libssl-dev` ‚Äî transitive native build.
#   * `git` ‚Äî some build scripts read worktree state.
#   * `cmake` ‚Äî required by `audiopus_sys` (PURA-154 wired the music-bot
#                 audio pipeline into ts6-manager-server, which pulls
#                 audiopus ‚Üí audiopus_sys ‚Üí libopus C build via cmake).
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        build-essential \
        pkg-config \
        libssl-dev \
        ca-certificates \
        cmake \
        git \
 && rm -rf /var/lib/apt/lists/*

# WASM client target for the dioxus-fullstack web bundle.
RUN rustup target add wasm32-unknown-unknown

# `dx` must be pinned to the dioxus runtime version (currently 0.7.7) ‚Äî version
# skew silently breaks asset URL substitution (impl-plan ¬ß10).
RUN cargo install dioxus-cli --version 0.7.7 --locked

COPY Cargo.toml ./
COPY rust-toolchain.toml ./
COPY crates ./crates

# Cargo.lock may not exist on a fresh checkout; tolerate either case.
COPY Cargo.loc[k] ./

# Build both the wasm client and the patched native server binary in one pass.
# Output layout (impl-plan ¬ß10) ‚Äî written under the workspace target dir:
#   target/dx/ts6-manager-server/release/web/server
#   target/dx/ts6-manager-server/release/web/public/{index.html,assets/*}
# `dx` reads `Dioxus.toml` from the crate root, so we run it from there to
# mirror the documented dev loop (`dx serve` from `crates/ts6-manager-server/`).
RUN cd crates/ts6-manager-server && dx bundle --release --fullstack

# -----------------------------------------------------------------------------
# Stage 2 ‚Äî runtime (non-root, slim)
# -----------------------------------------------------------------------------
FROM docker.io/debian:bookworm-slim

# Runtime deps:
#   * `ca-certificates`   ‚Äî outbound HTTPS to source URLs (yt-dlp, ICY).
#   * `curl`              ‚Äî in-container HTTP probe. `podman kube play`
#                           translates the kube manifest's `httpGet`
#                           liveness/readiness probes into a CMD-SHELL
#                           `curl -f http://host:port/path || exit 1`
#                           healthcheck and runs it *inside* the container ‚Äî
#                           not from the kubelet/host. Without curl the
#                           synthesized healthcheck exits non-zero, podman
#                           marks the pod unhealthy after 3 streaks, and
#                           crashloops it every 60-90s (PURA-191). The
#                           Quadlet `HealthCmd=curl ...` relies on the same
#                           binary.
#   * `libssl3`           ‚Äî transitive native deps even on rustls builds.
#   * `ffmpeg`            ‚Äî subprocess invoked by `crates/music-bot-audio` for
#                           both the direct-`Ffmpeg` and chained-`YtDlp` source
#                           paths (PCM s16le decode). PURA-190: without this,
#                           `Command::new("ffmpeg").spawn()` ENOENTs and the
#                           music-bot supervisor never advances past
#                           `Connected` ‚Äî V5 (audible audio) cannot pass.
#   * `yt-dlp`            ‚Äî subprocess invoked by `YtDlpSource::new` for every
#                           HTTP(S) `AudioSource::Url` (the only path the
#                           `/api/music-bots/{id}/play` REST surface exercises;
#                           see `crates/voice/src/audio.rs::source_to_spec`).
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        ffmpeg \
        libssl3 \
        yt-dlp \
 && rm -rf /var/lib/apt/lists/* \
 && groupadd --system --gid 10001 ts6 \
 && useradd --system --uid 10001 --gid ts6 --shell /usr/sbin/nologin --home-dir /var/lib/ts6-manager ts6 \
 && mkdir -p /var/lib/ts6-manager/db /var/lib/ts6-manager/music \
 && chown -R ts6:ts6 /var/lib/ts6-manager

# Copy the patched server binary AND the SSR/WASM static bundle next to it.
# `dioxus_server::config` panics at boot if `<binary-dir>/public/` is missing
# (PURA-75 wired the bundle copy; PURA-93 caught a regression where the
# runtime image was copying only the binary, so the server tripped on
# `Couldn't read public directory at "/usr/local/bin/public"` the moment
# `serve_dioxus_application` registered static assets).
COPY --from=builder /build/target/dx/ts6-manager-server/release/web/server /usr/local/bin/ts6-manager-server
COPY --from=builder /build/target/dx/ts6-manager-server/release/web/public /usr/local/bin/public

# OCI labels ‚Äî populated by the release helper (scripts/build-images.sh) via
# `--build-arg`. Defaults keep the image self-describing even on local builds.
ARG IMAGE_VERSION=dev
ARG IMAGE_REVISION=unknown
ARG IMAGE_SOURCE="https://github.com/FrozenTear/teamspeak-admin-panel"
LABEL org.opencontainers.image.title="ts6-manager-fullstack" \
      org.opencontainers.image.description="TS6 Manager ‚Äî Dioxus fullstack server (HTTP + WS + REST + SSR/WASM client)" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.source="${IMAGE_SOURCE}" \
      org.opencontainers.image.version="${IMAGE_VERSION}" \
      org.opencontainers.image.revision="${IMAGE_REVISION}"

USER ts6:ts6
WORKDIR /var/lib/ts6-manager

ENV PORT=3001 \
    NODE_ENV=production \
    DATABASE_URL=surrealkv:///var/lib/ts6-manager/db \
    MUSIC_DIR=/var/lib/ts6-manager/music

EXPOSE 3001

ENTRYPOINT ["/usr/local/bin/ts6-manager-server"]
