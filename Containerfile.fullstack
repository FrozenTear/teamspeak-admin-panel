# TS6 Manager ŌĆö Dioxus fullstack server
# Multi-stage OCI Containerfile (Podman-native; works with any OCI runtime).
#
# Multi-arch: builds cleanly under `podman build --platform linux/amd64` and
# `--platform linux/arm64`; we publish a manifest list spanning both at release
# time. See docs/ops/images.md for the release procedure.

# -----------------------------------------------------------------------------
# Stage 1 ŌĆö build
# -----------------------------------------------------------------------------
FROM docker.io/rust:1.95-slim-bookworm AS builder

WORKDIR /build

# Build-time deps:
#   * `build-essential` ŌĆö gcc / libc6-dev for the dx bundle link step.
#   * `pkg-config` / `libssl-dev` ŌĆö transitive native build.
#   * `git` ŌĆö some build scripts read worktree state.
#   * `cmake` ŌĆö required by `audiopus_sys` (PURA-154 wired the music-bot
#                 audio pipeline into ts6-manager-server, which pulls
#                 audiopus ŌåÆ audiopus_sys ŌåÆ libopus C build via cmake).
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        build-essential \
        pkg-config \
        libssl-dev \
        ca-certificates \
        cmake \
        git \
 && rm -rf /var/lib/apt/lists/*

# WASM client target for the dioxus-fullstack web bundle.
RUN rustup target add wasm32-unknown-unknown

# `dx` must be pinned to the dioxus runtime version (currently 0.7.7) ŌĆö version
# skew silently breaks asset URL substitution (impl-plan ┬¦10).
RUN cargo install dioxus-cli --version 0.7.7 --locked

COPY Cargo.toml ./
COPY rust-toolchain.toml ./
COPY crates ./crates

# Cargo.lock may not exist on a fresh checkout; tolerate either case.
COPY Cargo.loc[k] ./

# PURA-187 ŌĆö `.cargo/config.toml` carries the
# `--cfg=web_sys_unstable_apis` rustflag (PURA-143 WS-5). Without it the
# in-container `wasm32-unknown-unknown` build can't see web-sys's
# `WebTransport`, `VideoDecoder`, `AudioDecoder`, `AudioData`,
# `AudioSampleFormat`, etc., and the video_player widget fails to
# compile ŌĆö turning PURA-185's `--platform web` switch into a hard
# stage-1 build failure instead of a silent CSS-only release. The
# v0.1.0-rc1 image hid the missing flag because its "client" was being
# built as `BundleFormat::Server`, so this code never type-checked for
# wasm at all.
COPY .cargo ./.cargo

# Build both the wasm client and the patched native server binary in one pass.
# Output layout (impl-plan ┬¦10) ŌĆö written under the workspace target dir:
#   target/dx/ts6-manager-server/release/web/server
#   target/dx/ts6-manager-server/release/web/public/{index.html,assets/*}
# `dx` reads `Dioxus.toml` from the crate root, so we run it from there to
# mirror the documented dev loop (`dx serve` from `crates/ts6-manager-server/`).
#
# PURA-185 ŌĆö `--platform web` is required even with `--fullstack`. Without
# it, dx-CLI 0.7.7 autodetects the client platform from the crate's
# `default = ["server"]` (the only default-enabled renderer feature) and
# falls into the `cli/build.rs:131` fast-path that skips the wasm client
# build entirely when the requested platform IS already server. The
# server still processes `asset!()` macros so `public/assets/*.css`
# appears, but no `*.wasm`/`*.js`/`index.html` is emitted and the SPA
# ships with zero client-side interactivity. `--platform web` pins the
# client target to wasm32 and `--fullstack` adds the server build into
# the same `web/` folder.
RUN cd crates/ts6-manager-server && dx bundle --release --platform web --fullstack

# PURA-185 post-build assertion ŌĆö fail the image build loudly if the wasm
# client bundle is missing, instead of silently shipping a non-interactive
# SSR shell. Catches both "wrong dx invocation" (whole client build
# skipped) and "output landed in a sibling directory we don't COPY"
# regressions. dx-CLI 0.7.7 emits hashed `*_bg.wasm` + the wasm-bindgen
# `.js` shim under `public/assets/`, with `index.html` at the
# `public/` root referencing them ŌĆö assert all three.
RUN set -eu; \
    public="/build/target/dx/ts6-manager-server/release/web/public"; \
    server="/build/target/dx/ts6-manager-server/release/web/server"; \
    test -f "$server"            || { echo "FATAL: missing server binary at $server"; exit 1; }; \
    test -f "$public/index.html" || { echo "FATAL: missing $public/index.html"; ls -lR "$public" || true; exit 1; }; \
    find "$public" -name '*.wasm' -print -quit | grep -q . \
        || { echo "FATAL: no *.wasm under $public ŌĆö wasm client bundle did not build"; ls -lR "$public" || true; exit 1; }; \
    find "$public" -name '*.js' -print -quit | grep -q . \
        || { echo "FATAL: no *.js loader under $public"; ls -lR "$public" || true; exit 1; }; \
    grep -q '<script[^>]*\.js' "$public/index.html" \
        || { echo "FATAL: $public/index.html has no <script src=...> tag ŌĆö hydration entry missing"; cat "$public/index.html"; exit 1; }; \
    echo "[PURA-185] post-build assertion: wasm + js + index.html present and wired in $public"

# -----------------------------------------------------------------------------
# Stage 2 ŌĆö runtime (non-root, slim)
# -----------------------------------------------------------------------------
FROM docker.io/debian:bookworm-slim

# Runtime deps:
#   * `ca-certificates`   ŌĆö outbound HTTPS to source URLs (yt-dlp, ICY).
#   * `curl`              ŌĆö in-container HTTP probe. `podman kube play`
#                           translates the kube manifest's `httpGet`
#                           liveness/readiness probes into a CMD-SHELL
#                           `curl -f http://host:port/path || exit 1`
#                           healthcheck and runs it *inside* the container ŌĆö
#                           not from the kubelet/host. Without curl the
#                           synthesized healthcheck exits non-zero, podman
#                           marks the pod unhealthy after 3 streaks, and
#                           crashloops it every 60-90s (PURA-191). The
#                           Quadlet `HealthCmd=curl ...` relies on the same
#                           binary.
#   * `libssl3`           ŌĆö transitive native deps even on rustls builds.
#   * `ffmpeg`            ŌĆö subprocess invoked by `crates/music-bot-audio` for
#                           both the direct-`Ffmpeg` and chained-`YtDlp` source
#                           paths (PCM s16le decode). PURA-190: without this,
#                           `Command::new("ffmpeg").spawn()` ENOENTs and the
#                           music-bot supervisor never advances past
#                           `Connected` ŌĆö V5 (audible audio) cannot pass.
#   * `yt-dlp`            ŌĆö subprocess invoked by `YtDlpSource::new` for every
#                           HTTP(S) `AudioSource::Url` (the only path the
#                           `/api/music-bots/{id}/play` REST surface exercises;
#                           see `crates/voice/src/audio.rs::source_to_spec`).
# Pin yt-dlp to a known-good upstream release. The Debian Bookworm apt package
# is pinned at 2023.03.04 ŌĆö too old for YouTube's current cipher/sig mechanism.
# Bump this ARG when YouTube stops working again (keep the pin explicit so a
# future regression is a deliberate, reviewed change ŌĆö not a silent `latest`
# pull at build time).
ARG YTDLP_VERSION=2025.01.26
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        ffmpeg \
        libssl3 \
        python3 \
 && curl -fsSL -o /usr/local/bin/yt-dlp \
        "https://github.com/yt-dlp/yt-dlp/releases/download/${YTDLP_VERSION}/yt-dlp" \
 && chmod 0755 /usr/local/bin/yt-dlp \
 && yt-dlp --version \
 && rm -rf /var/lib/apt/lists/* \
 && groupadd --system --gid 10001 ts6 \
 && useradd --system --uid 10001 --gid ts6 --shell /usr/sbin/nologin --home-dir /var/lib/ts6-manager ts6 \
 && mkdir -p /var/lib/ts6-manager/db /var/lib/ts6-manager/music \
 && chown -R ts6:ts6 /var/lib/ts6-manager

# Copy the patched server binary AND the SSR/WASM static bundle next to it.
# `dioxus_server::config` panics at boot if `<binary-dir>/public/` is missing
# (PURA-75 wired the bundle copy; PURA-93 caught a regression where the
# runtime image was copying only the binary, so the server tripped on
# `Couldn't read public directory at "/usr/local/bin/public"` the moment
# `serve_dioxus_application` registered static assets).
COPY --from=builder /build/target/dx/ts6-manager-server/release/web/server /usr/local/bin/ts6-manager-server
COPY --from=builder /build/target/dx/ts6-manager-server/release/web/public /usr/local/bin/public

# OCI labels ŌĆö populated by the release helper (scripts/build-images.sh) via
# `--build-arg`. Defaults keep the image self-describing even on local builds.
ARG IMAGE_VERSION=dev
ARG IMAGE_REVISION=unknown
ARG IMAGE_SOURCE="https://github.com/FrozenTear/teamspeak-admin-panel"
LABEL org.opencontainers.image.title="ts6-manager-fullstack" \
      org.opencontainers.image.description="TS6 Manager ŌĆö Dioxus fullstack server (HTTP + WS + REST + SSR/WASM client)" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.source="${IMAGE_SOURCE}" \
      org.opencontainers.image.version="${IMAGE_VERSION}" \
      org.opencontainers.image.revision="${IMAGE_REVISION}"

USER ts6:ts6
WORKDIR /var/lib/ts6-manager

ENV PORT=3001 \
    NODE_ENV=production \
    DATABASE_URL=surrealkv:///var/lib/ts6-manager/db \
    MUSIC_DIR=/var/lib/ts6-manager/music

EXPOSE 3001

ENTRYPOINT ["/usr/local/bin/ts6-manager-server"]
